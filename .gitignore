# gitから除外するファイル

## 基本全部無視
/*

## 除外指定
!vimrc
!gvimrc
!.gitignore

### plugin
!/plugin/
/plugin/*
!/plugin/*.vim
!/plugin/command/
!/plugin/command/*.vim

### autoload
!/autoload/
/autoload/*
!/autoload/*.vim
/autoload/plug.vim

### pack
!/pack/myplug/opt/*/plugin/*
!/pack/colorscheme/start/

### ftplugin
!/ftplugin/
/ftplugin/*
!/ftplugin/*.vim

### vim-plug
!/vim-plug/
/vim-plug/*
!/vim-plug/*.vim
/vim-plug/*.vim/
